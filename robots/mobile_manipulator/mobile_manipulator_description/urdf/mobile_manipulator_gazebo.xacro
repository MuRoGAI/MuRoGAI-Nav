    <!-- ============================================ -->
    <!-- BASE LINK PROPERTIES -->
    <!-- ============================================ -->
    <gazebo reference="${frame_prefix}base_link">
      <mu1>0.1</mu1>
      <mu2>0.1</mu2>
      <material>Gazebo/Cyan</material>
    </gazebo>

    <!-- ============================================ -->
    <!-- ARM LINK PROPERTIES -->
    <!-- ============================================ -->
