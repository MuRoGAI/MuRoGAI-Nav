          <position_cmd_max>5</position_cmd_max>
          
          <joint_name>${frame_prefix}ur_joint5</joint_name>
          <initial_position>0.0</initial_position>
          <position_p_gain>3</position_p_gain>
          <position_i_gain>0.05</position_i_gain>
          <position_d_gain>0.3</position_d_gain>
          <position_i_min>-1</position_i_min>
          <position_i_max>1</position_i_max>
          <position_cmd_min>-5</position_cmd_min>
          <position_cmd_max>5</position_cmd_max>
          
          <joint_name>${frame_prefix}ur_joint6</joint_name>
          <initial_position>0.0</initial_position>
          <position_p_gain>2</position_p_gain>
          <position_i_gain>0.02</position_i_gain>
          <position_d_gain>0.2</position_d_gain>
          <position_i_min>-1</position_i_min>
          <position_i_max>1</position_i_max>
          <position_cmd_min>-3</position_cmd_min>
          <position_cmd_max>3</position_cmd_max>
          
          <topic>${namespace}/arm_cmds</topic>
        </plugin> -->

        <!-- DIFF DRIVE CONTROLLER -->
        <plugin filename="gz-sim-diff-drive-system"
                name="gz::sim::systems::DiffDrive">
          
          <left_joint>${frame_prefix}fl_wheel_joint</left_joint>
          <right_joint>${frame_prefix}fr_wheel_joint</right_joint>
          
          <wheel_separation>0.27</wheel_separation>
          <wheel_radius>0.04445</wheel_radius>
          
          <topic>${namespace}/cmd_vel</topic>
          <!-- <update_rate>200</update_rate> -->
          
          <!-- <odom_publish_frequency>50</odom_publish_frequency> -->
          <!-- <frame_id>${frame_prefix}odom</frame_id>
          <child_frame_id>${frame_prefix}base_footprint</child_frame_id> -->

          <publish_odom>false</publish_odom>
          <publish_odom_tf>false</publish_odom_tf>
          
          <!-- <tf_topic>/tf</tf_topic> -->
          <!-- <odom_topic>${namespace}/odom</odom_topic> -->
        </plugin>

        <plugin filename="ignition-gazebo-odometry-publisher-system"
                name="ignition::gazebo::systems::OdometryPublisher">
            <odom_frame>${frame_prefix}odom</odom_frame>
            <robot_base_frame>${frame_prefix}base_footprint</robot_base_frame>
            <odom_publish_frequency>200</odom_publish_frequency>
            <odom_topic>${namespace}/odom</odom_topic>
            <odom_covariance_topic>${namespace}/odometry_with_covariance</odom_covariance_topic>
            <tf_topic>/tf</tf_topic>
        </plugin>


        <!-- JOINT STATE PUBLISHER -->
        <plugin filename="ignition-gazebo-joint-state-publisher-system" 
                name="ignition::gazebo::systems::JointStatePublisher">
          <topic>${namespace}/joint_states</topic>
          <update_rate>50</update_rate>
        </plugin>
      </gazebo>
    </xacro:if>



