          <joint_name>${frame_prefix}ur_joint3</joint_name>
          <initial_position>0.0</initial_position>
          <position_p_gain>5</position_p_gain>
          <position_i_gain>0.1</position_i_gain>
          <position_d_gain>0.5</position_d_gain>
          <position_i_min>-1</position_i_min>
          <position_i_max>1</position_i_max>
          <position_cmd_min>-10</position_cmd_min>
          <position_cmd_max>10</position_cmd_max>
          
          <joint_name>${frame_prefix}ur_joint4</joint_name>
          <initial_position>0.0</initial_position>
          <position_p_gain>3</position_p_gain>
          <position_i_gain>0.05</position_i_gain>
          <position_d_gain>0.3</position_d_gain>
