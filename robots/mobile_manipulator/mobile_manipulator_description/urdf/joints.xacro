  <!-- ============================================ -->
  <!-- WHEEL JOINTS - DIRECTLY ATTACHED TO BASE -->
  <!-- ============================================ -->
  
  <!-- Front Right Wheel - Now directly attached to base_link -->
  <joint name="${frame_prefix}fr_wheel_joint" type="continuous">
    <origin xyz="${wheel_x_offset} ${-wheel_y_offset} ${wheel_z_offset}" rpy="-1.5708 0 0"/>
    <parent link="${frame_prefix}base_link"/>
    <child link="${frame_prefix}fr_wheel"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <!-- Front Left Wheel - Now directly attached to base_link -->
  <joint name="${frame_prefix}fl_wheel_joint" type="continuous">
    <origin xyz="${wheel_x_offset} ${wheel_y_offset} ${wheel_z_offset}" rpy="-1.5708 0 0"/>
    <parent link="${frame_prefix}base_link"/>
    <child link="${frame_prefix}fl_wheel"/>
    <axis xyz="0 0 1"/>
  </joint>
  
