  <!-- ============================================ -->
  <!-- CASTER WHEEL (SPHERE FOR OMNIDIRECTIONAL) -->
  <!-- ============================================ -->
  <link name="${frame_prefix}caster_wheel">
    <!-- Inertia for a sphere: I = 2/5 * m * r^2 -->
    <!-- <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${caster_mass}"/>
      <inertia
        ixx="0.0001" ixy="0.0" ixz="0.0"
        iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial> -->
    <xacro:inertial_sphere mass="${caster_mass}" radius="${caster_radius}">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_sphere>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Sphere for omnidirectional rolling -->
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
  </link>

  <link name="${frame_prefix}top_plate_link">
    <!-- Visual -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.35 0.01"/>  <!-- 22cm × 22cm × 1cm -->
      </geometry>
       <material name="cyan"/>
    </visual>

    <!-- Collision -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.35 0.01"/>
      </geometry>
    </collision>

    <!-- Inertial -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>  <!-- 300 grams -->
      <inertia
        ixx="0.0005" ixy="0" ixz="0"
        iyy="0.0005" iyz="0"
        izz="0.0004"/>
    </inertial>
  </link>



</robot>