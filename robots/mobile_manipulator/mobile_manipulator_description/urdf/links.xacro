  <!-- ============================================ -->
  <!-- FRONT WHEELS (CYLINDERS INSTEAD OF STL) -->
  <!-- ============================================ -->
  
  <!-- Front Right Wheel - Using Cylinder Geometry -->
  <link name="${frame_prefix}fr_wheel">
    <!-- Inertia for a cylinder: I = m*r^2/2 (roll), I = m*(3*r^2 + h^2)/12 (pitch/yaw) -->
    <!-- <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${wheel_mass}"/>
      <inertia
        ixx="0.0300470784455855" ixy="0.0" ixz="0.0"
        iyy="0.0500929586200209" iyz="0.0" izz="0.0300470784455855"/>
    </inertial> -->
    <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_width}" radius="${wheel_radius}">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Cylinder: radius and length (height along y-axis when rpy="0 0 0") -->
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black_rubber"/>
    </visual>
    <!-- STL mesh version - COMMENTED OUT -->
    <!-- <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://mobile_manipulator_description/meshes/fr_wheel.STL"/>
      </geometry>
      <material name="black_rubber"/>
    </visual> -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <!-- STL mesh collision - COMMENTED OUT -->
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://mobile_manipulator_description/meshes/fr_wheel.STL"/>
      </geometry>
    </collision> -->
  </link>
  
  <!-- Front Left Wheel - Using Cylinder Geometry -->
