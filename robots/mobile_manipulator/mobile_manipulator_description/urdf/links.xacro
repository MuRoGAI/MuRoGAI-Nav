<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  
  <!-- ============================================ -->
  <!-- BASE FOOTPRINT -->
  <!-- ============================================ -->
  <link name="${frame_prefix}base_footprint"/>
  
  <!-- ============================================ -->
  <!-- BASE LINK -->
  <!-- ============================================ -->
  <link name="${frame_prefix}base_link">
    <!-- <inertial>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <mass value="${base_mass}"/>
      <inertia
        ixx="0.160894" ixy="0.0" ixz="0.0"
        iyy="0.288892" iyz="0.0" izz="0.160887"/>
    </inertial> -->
    <xacro:inertial_box mass="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}">
        <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
    </xacro:inertial_box>
    <visual>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <!-- Box representing the base platform -->
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
       <material name="cyan"/>
    </visual>
    <!-- STL mesh version - COMMENTED OUT -->
    <!-- <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://mobile_manipulator_description/meshes/base_link.STL"/>
      </geometry>
       <material name="cyan"/>
    </visual> -->
    <collision>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <!-- Slightly smaller collision box to prevent wheel interference -->
        <box size="${base_length - 0.02} ${base_width - 0.02} ${base_height}"/>
      </geometry>
    </collision>
    <!-- STL mesh collision - COMMENTED OUT -->
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://mobile_manipulator_description/meshes/base_link.STL"/>
      </geometry>
    </collision> -->
  </link>
  
